{
  "productName": "fps-test",
  "identifier": "com.tauri-plugin-macos-fps.test",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FPS Test — tauri-plugin-macos-fps",
        "width": 600,
        "height": 500,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "macos-fps": {
      "enabled": true
    }
  }
}
